# Test de funciones y recursividad
mesa_crafteo bloques potencia(bloques base, bloques exp):
    observador (exp == 0):
        craftear 1;
    fin
    craftear base * potencia(base, exp - 1);
fin

mesa_crafteo vacío saludar(texto nombre):
    letrero("Hola, " + nombre + "!");
fin

mesa_crafteo bloques max(bloques a, bloques b):
    observador (a > b):
        craftear a;
    fin
    craftear b;
fin

mesa_crafteo vacío main():
    letrero("=== Test: Funciones ===");
    
    # Test función sin retorno
    saludar("Steve");
    saludar("Alex");
    
    # Test función con retorno
    bloques resultado = max(15, 8);
    letrero("Máximo(15, 8) = " + to_texto(resultado));
    
    # Test recursividad
    bloques pot = potencia(2, 5);
    letrero("2^5 = " + to_texto(pot));
    
    letrero("✓ Test completado");
fin
