# Test de conversiones de tipo
mesa_crafteo vacío main():
    letrero("=== Test: Conversiones de Tipo ===");
    
    # String a int
    texto str_num = "123";
    bloques entero = to_bloques(str_num);
    letrero("to_bloques('123') = " + to_texto(entero));
    
    # String a float
    texto str_float = "3.14";
    coordenada decimal = to_coordenada(str_float);
    letrero("to_coordenada('3.14') = " + to_texto(decimal));
    
    # Int a string
    bloques num = 42;
    texto str_resultado = to_texto(num);
    letrero("to_texto(42) = " + str_resultado);
    
    # String a char
    texto letra_str = "A";
    glifo letra = to_glifo(letra_str);
    letrero("to_glifo('A') = " + to_texto(letra));
    
    # Boolean a string
    redstone verdad = verdadero;
    letrero("to_texto(verdadero) = " + to_texto(verdad));
    
    letrero("✓ Test completado");
fin
