# Test de diccionarios (mapa)
mesa_crafteo vacío main():
    letrero("=== Test: Diccionarios (Mapa) ===");
    
    mapa<texto, bloques> recursos = {};
    
    recursos["oro"] = 10;
    recursos["hierro"] = 25;
    recursos["diamante"] = 3;
    
    letrero("Inventario creado");
    
    bloques oro = recursos["oro"];
    bloques hierro = recursos["hierro"];
    bloques diamante = recursos["diamante"];
    
    letrero("Oro: " + to_texto(oro));
    letrero("Hierro: " + to_texto(hierro));
    letrero("Diamante: " + to_texto(diamante));
    
    recursos["oro"] = 15;
    bloques oro_nuevo = recursos["oro"];
    letrero("Oro después de modificar: " + to_texto(oro_nuevo));
    
    letrero("✓ Test completado");
fin
