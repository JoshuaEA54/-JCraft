# Test de operadores aritméticos
mesa_crafteo vacío main():
    letrero("=== Test: Operadores Aritméticos ===");
    
    bloques a = 10;
    bloques b = 3;
    
    bloques suma = a + b;
    bloques resta = a - b;
    bloques multi = a * b;
    bloques division = a / b;
    bloques modulo = a % b;
    
    letrero("a = 10, b = 3");
    letrero("Suma: " + to_texto(suma));
    letrero("Resta: " + to_texto(resta));
    letrero("Multiplicación: " + to_texto(multi));
    letrero("División: " + to_texto(division));
    letrero("Módulo: " + to_texto(modulo));
    
    letrero("✓ Test completado");
fin
