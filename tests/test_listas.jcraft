# Test de listas (inventario)
mesa_crafteo vacío main():
    letrero("=== Test: Listas (Inventario) ===");
    
    inventario<bloques> numeros = [10, 20, 30, 40, 50];
    
    letrero("Lista original: [10, 20, 30, 40, 50]");
    
    # Acceder elementos
    bloques primero = numeros[0];
    bloques ultimo = numeros[4];
    
    letrero("Primer elemento: " + to_texto(primero));
    letrero("Último elemento: " + to_texto(ultimo));
    
    # Modificar elemento
    numeros[2] = 100;
    bloques modificado = numeros[2];
    letrero("Elemento [2] modificado a: " + to_texto(modificado));
    
    # Recorrer lista
    letrero("Recorriendo lista:");
    bloques i = 0;
    cultivar (i = 0; i < 5; i = i + 1):
        bloques elem = numeros[i];
        letrero("  [" + to_texto(i) + "] = " + to_texto(elem));
    cosechar
    
    letrero("✓ Test completado");
fin
