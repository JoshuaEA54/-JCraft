# Test de operadores lógicos
mesa_crafteo vacío main():
    letrero("=== Test: Operadores Lógicos ===");
    
    redstone verdad = verdadero;
    redstone mentira = falso;
    
    redstone and_result = verdad y verdad;
    redstone or_result = verdad o mentira;
    redstone not_result = no mentira;
    
    letrero("verdadero Y verdadero = " + to_texto(and_result));
    letrero("verdadero O falso = " + to_texto(or_result));
    letrero("NO falso = " + to_texto(not_result));
    
    letrero("✓ Test completado");
fin
